        "jsCode": "// Parsear la respuesta del dashboard de forma segura\nconst raw = $input.item.json.data || $input.item.json.body || '{}';\nlet parsed = { botActive: true, priority: 'normal', handoff_reason: null, found: false };\n\ntry {\n  const text = typeof raw === 'string' ? raw : JSON.stringify(raw);\n  // Si es JSON válido del API\n  if (text.trim().startsWith('{')) {\n    parsed = JSON.parse(text);\n  }\n  // Si es HTML del frontend (server no deployado aún) -> dejar pasar el bot\n} catch(e) {\n  // Fallo silencioso -> bot activo por defecto\n}\n\nreturn { json: parsed };"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,

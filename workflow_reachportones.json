    {
      "parameters": {
        "jsCode": "// 1. Detectamos el horario de ejecución\nconst horaActual = $now.hour;\nconst esReporteNocturno = horaActual >= 18; \n\n// 2. Extraemos los datos de entrada\nconst citas = $input.all();\n\n// 3. Definimos encabezados según el momento\nlet tituloAgenda = esReporteNocturno ? \"MAÑANA\" : \"HOY\";\nlet subtitulo = esReporteNocturno \n  ? \"_Revisa tus servicios programados para el siguiente día._\" \n  : \"_Estos son tus servicios confirmados para la jornada actual._\";\n\nlet mensaje = `📝 *AGENDA PARA ${tituloAgenda}* 🗓️\\n${subtitulo}\\n\\n`;\n\n// 4. Construcción del listado\nif (citas.length === 0) {\n  mensaje += \"✅ *Sin pendientes:* No hay citas registradas para este periodo.\";\n} else {\n  citas.forEach((cita, index) => {\n    const json = cita.json;\n    const hora = json.time || 'Hora por confirmar';\n    const titulo = (json.title || 'Servicio Técnico').toUpperCase();\n    const lugar = json.location || 'Consultar ubicación';\n    const desc = json.description ? `\\n📝 *Detalles:* ${json.description}` : '';\n\n    mensaje += `*${index + 1}. ⏰ ${hora}* - *${titulo}*\\n`;\n    mensaje += `📍 *Lugar:* ${lugar}${desc}\\n`;\n    mensaje += `--------------------------\\n`;\n  });\n  \n  mensaje += \"\\n💪 _¡Buen camino, OneControl te desea un gran día!_\";\n}\n\nreturn { texto_final: mensaje };"
      },
      "id": "a9b97d39-6371-4299-8b9a-bdc93aa0557d",
